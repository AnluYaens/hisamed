├── src/
│   ├── app/                     # Next.js App Router (páginas y layouts)
│   │   ├── (auth)/              # Grupo: login, registro
│   │   ├── (dashboard)/         # Grupo: app autenticada
│   │   │   ├── patients/
│   │   │   ├── appointments/
│   │   │   ├── clinical-notes/
│   │   │   └── settings/
